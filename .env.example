# ──────────────────────────────────────────────
# Development environment
# Next.js loads this when NODE_ENV=development
# ──────────────────────────────────────────────
# Copy these placeholders into .env.development
DATABASE_URL="postgresql://USER:PASSWORD@POOLED_DEV_HOST/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_DEV_HOST/DATABASE?sslmode=require"

# ──────────────────────────────────────────────
# Production environment
# Set these in Vercel dashboard (never commit)
# ──────────────────────────────────────────────
# DATABASE_URL="postgresql://USER:PASSWORD@POOLED_PROD_HOST/DATABASE?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_PROD_HOST/DATABASE?sslmode=require"

# ──────────────────────────────────────────────
# Shared config (same for all environments)
# ──────────────────────────────────────────────
SUPER_ADMIN_EMAILS="admin@example.com"

BETTER_AUTH_SECRET="replace-with-a-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

BLOB_READ_WRITE_TOKEN="replace-with-a-vercel-blob-token"
